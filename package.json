{
    "name": "nextjs-mongo-template",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "cross-env NODE_OPTIONS=--max-old-space-size=512 next dev --hostname 0.0.0.0 --port 3000 --webpack",
        "dev:no-reload": "next dev --hostname 0.0.0.0 --port 3000",
        "dev:webpack": "next dev --hostname 0.0.0.0 --port 3000",
        "build": "next build",
        "start": "cross-env PORT=3000 next start --hostname 127.0.0.1 --port 3000",
        "start:local20": "cross-env PORT=3000 next start --hostname 127.0.0.1 --port 3000",
        "start:3001": "cross-env PORT=3001 next start --hostname 127.0.0.1 --port 3001",
        "db:start": "docker-compose up -d",
        "db:stop": "docker-compose down",
        "db:restart": "docker-compose restart",
        "db:status": "docker-compose ps",
        "db:logs": "docker-compose logs -f",
        "db:reset": "docker-compose down -v && docker-compose up -d",
        "dev:full": "npm run db:start && npm run dev",
        "dev:full:reset": "npm run db:reset && npm run dev"
    },
    "engines": {
        "node": ">=18.17"
    },
