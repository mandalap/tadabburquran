# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
# For production, use DATABASE_URL with SSL
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Or separate variables (for development):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=tadabburquran
# DB_PASSWORD=your_secure_password
# DB_NAME=tadabburquran_db

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# NEXT.JS CONFIG
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_generate_with_openssl_rand_base64_32

# Production: Set your actual domain (comma separated for multiple)
# Development: defaults to localhost:3000
CORS_ORIGINS=https://tadabburquran.id,https://www.tadabburquran.id

# ============================================
# NEXTAUTH / GOOGLE OAUTH
# ============================================
# Get credentials from: https://console.cloud.google.com/
NEXTAUTH_URL=http://localhost:3000
# In production, set: NEXTAUTH_URL=https://tadabburquran.id
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# EMAIL CONFIGURATION (Resend)
# Get API key from: https://resend.com/api-keys
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxx
# Development: Uses onboarding@resend.dev by default
# Production: Use your verified domain
EMAIL_FROM=Tadabbur Quran <noreply@tadabburquran.id>
# For Resend free tier testing, all emails go to this address:
DEV_EMAIL=juli23man@gmail.com

# ============================================
# PAYMENT GATEWAY (Midtrans)
# Get credentials from: https://dashboard.midtrans.com/
# ============================================
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxx
PAYMENT_SECRET=

# ============================================
# JWT SECRET (for custom auth)
# ============================================
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRES_IN=7d

# ============================================
# NODE ENV
# ============================================
# development | production
NODE_ENV=development
